<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration
    - Blocks all cleartext (HTTP) traffic in release builds.
    - HTTPS is always required for the production API (breatheonline.app).
    - Debug builds retain cleartext access for local dev servers.
-->
<network-security-config>

    <!-- Production: HTTPS only, no cleartext permitted -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">breatheonline.app</domain>
    </domain-config>

    <!-- Local dev: cleartext to localhost is fine (traffic never leaves device) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- Debug only: trust user-installed CAs (Charles / mitmproxy) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

</network-security-config>
